# WISHUB environment — copy to `.env` and fill in. Placeholders only here.
# Real values go in your local `.env` (gitignored) or Replit's Secrets panel.

# --- Database (Postgres) -----------------------------------------------------
# Replit provides this automatically when you add its PostgreSQL database.
# Locally, point at your own Postgres. If unset, the app runs in localStorage
# mode (no accounts, progress saved per-browser only).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# --- Sessions ----------------------------------------------------------------
# Secret used to sign the session JWT. Generate one with:
#   openssl rand -base64 32
# If unset, login/signup are disabled and the app stays in localStorage mode.
AUTH_SECRET="replace-with-a-long-random-string"

# Public base URL of the app. Used to build the Google OAuth redirect URI.
# On Replit set this to your deployment URL (https://<your-repl>.replit.app).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Google OAuth (optional) -------------------------------------------------
# Manual username/password signup works WITHOUT these. To enable
# "Continue with Google", create an OAuth 2.0 Web client at
#   https://console.cloud.google.com/apis/credentials
# and add this Authorized redirect URI:
#   <NEXT_PUBLIC_APP_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Admin -------------------------------------------------------------------
# Comma-separated emails always treated as admin (survives DB resets).
ADMIN_EMAILS="cavilla@uach.mx"
