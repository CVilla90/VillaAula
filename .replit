# VillaAula — Replit config (Next.js 16 + Postgres, Autoscale deployment).
# The Postgres module provides DATABASE_URL automatically; set the rest in
# the Secrets panel (see HANDOFF.md §17). Next.js honors PORT (set below) and
# binds to 0.0.0.0 by default, which is what Replit needs.
modules = ["nodejs-20", "web", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "node_modules", ".next"]

[nix]
channel = "stable-24_05"

[env]
# Next.js reads PORT for both `next dev` and `next start`; Replit serves :5000.
PORT = "5000"

[deployment]
deploymentTarget = "autoscale"
# `npm install` (run automatically by Replit) triggers `postinstall: prisma
# generate`. Do NOT add a separate install step here.
build = ["npm", "run", "build"]
run = ["npm", "run", "start"]

[[ports]]
localPort = 5000
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000
